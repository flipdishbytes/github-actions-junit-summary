{
  "name": "@flipdishbytes/github-actions-junit-summary",
  "version": "1.0.0",
  "description": "GitHub Action that turns JUnit XML into job summaries and error annotations.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/bin.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "test": "node --import tsx --test src/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "fast-glob": "^3.3.2",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
